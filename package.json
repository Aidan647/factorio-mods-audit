{
  "name": "mybuntemplate",
  "module": "src/index.ts",
  "private": true,
  "scripts": {
    "format-report": "bun run tools/format-report.ts",
    "scan": "bun run src/cli/scan-command.ts",
    "scan-top": "bun run src/cli/scan-top-command.ts",
    "scan-zip": "bun run tools/scan-zip.ts",
    "serve": "bun run src/cli/server-command.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "format": "prettier --write ."
  },
  "type": "module",
  "dependencies": {
    "sharp": "^0.35.3",
    "unzipit": "^2.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2",
    "prettier": "^3.9.4"
  }
}
