# Factorio Mod Portal credentials
FACTORIO_USERNAME=your_username
FACTORIO_TOKEN=your_token

# Legacy auth (fallback if FACTORIO_USERNAME/TOKEN not set)
USERNAME=username
TOKEN=token

# Data directory (stores cache + reports)
DATA_DIR=./data

# Cache settings
DISABLE_DISK_CACHE=false
CACHE_EXPIRY_MS=2592000000 # 30 days in milliseconds, 86400000 for 1 day
MODPORTAL_CACHE_DIR=./data/cache/modportal

# ClamAV
DISABLE_CLAMAV=false

# Override individual paths (optional)
CACHE_DIR=./data/cache
REPORTS_DIR=./data/reports
INDEX_PATH=./data/cache/scanned.json

# Rule file paths
CLUTTER_RULES_PATH=./data/clutter-rules.json5
IMAGE_RULES_PATH=./data/image-rules.json5
